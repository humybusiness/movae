{
  "name": "movae",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "Movaé — pauses actives intelligentes pour les journées devant l'écran",
  "author": "Movaé",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "desktop:dev": "vite build --mode desktop && electron .",
    "desktop:build": "tsc --noEmit -p tsconfig.json && vite build --mode desktop && electron-builder --win -c.directories.output=%LOCALAPPDATA%/movae-release"
  },
  "build": {
    "appId": "fr.movae.app",
    "productName": "Movae",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-desktop/**",
      "electron/**",
      "build-assets/icon-256.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "build-assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Movaé",
      "artifactName": "Movae-Setup.${ext}"
    }
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.0",
    "@fontsource-variable/manrope": "^5.2.0",
    "@react-three/fiber": "^9.6.1",
    "firebase": "^11.10.0",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.0.0"
  }
}
